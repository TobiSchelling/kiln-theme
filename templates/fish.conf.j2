# {{ display_name }} — Fish shell colors
# Generated by kiln-theme v{{ version }}
#
# Source this file or copy into your fish config:
#   source ~/.config/fish/themes/kiln-{{ variant }}.fish

# Syntax highlighting
set -U fish_color_normal         {{ colors.text.hex_stripped }}
set -U fish_color_command        {{ colors.sapphire.hex_stripped }}
set -U fish_color_keyword        {{ colors.mauve.hex_stripped }}
set -U fish_color_param          {{ colors.peach.hex_stripped }}
set -U fish_color_quote          {{ colors.green.hex_stripped }}
set -U fish_color_redirection    {{ colors.pink.hex_stripped }}
set -U fish_color_end            {{ colors.peach.hex_stripped }}
set -U fish_color_comment        {{ colors.comment.hex_stripped }}
set -U fish_color_error          {{ colors.red.hex_stripped }}
set -U fish_color_escape         {{ colors.rose.hex_stripped }}
set -U fish_color_operator       {{ colors.pink.hex_stripped }}
set -U fish_color_autosuggestion {{ colors.comment.hex_stripped }}
set -U fish_color_valid_path     --underline

# Selection
set -U fish_color_selection      --background={{ colors.surface1.hex_stripped }}
set -U fish_color_search_match   --background={{ colors.surface1.hex_stripped }} --bold

# Pager (completions)
set -U fish_pager_color_progress     {{ colors.comment.hex_stripped }}
set -U fish_pager_color_prefix       {{ colors.sapphire.hex_stripped }} --bold
set -U fish_pager_color_completion   {{ colors.subtext1.hex_stripped }}
set -U fish_pager_color_description  {{ colors.comment.hex_stripped }}
set -U fish_pager_color_selected_background --background={{ colors.surface0.hex_stripped }}
