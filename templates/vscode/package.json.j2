{
  "name": "kiln-{{ variant }}",
  "displayName": "{{ display_name }}",
  "description": "Kiln — {{ display_name }} color theme",
  "version": "{{ version }}",
  "publisher": "tobias",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Themes"],
  "contributes": {
    "themes": [
      {
        "label": "{{ display_name }}",
        "uiTheme": "{% if variant in ('ember', 'forge') %}vs-dark{% else %}vs{% endif %}",
        "path": "./themes/kiln.json"
      }
    ]
  }
}
