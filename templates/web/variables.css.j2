/* {{ display_name }} — CSS Custom Properties
 * Generated by kiln-theme v{{ version }}
 *
 * Usage: @import url('./kiln-{{ variant }}.css');
 *        body { background: var(--kiln-base); color: var(--kiln-text); }
 */

:root {
  /* Base & Surface */
  {% for name, c in base_colors.items() %}
  --kiln-{{ name }}: {{ c.hex }};
  {% endfor %}

  /* Text */
  {% for name, c in text_colors.items() %}
  --kiln-{{ name }}: {{ c.hex }};
  {% endfor %}

  /* Accents */
  {% for name, c in accent_colors.items() %}
  --kiln-{{ name }}: {{ c.hex }};
  {% endfor %}

  /* Semantic UI */
  --kiln-error: var(--kiln-red);
  --kiln-warning: var(--kiln-yellow);
  --kiln-success: var(--kiln-green);
  --kiln-info: var(--kiln-sky);
  --kiln-link: var(--kiln-sky);
  --kiln-selection: var(--kiln-blue);
}
