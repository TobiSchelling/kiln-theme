{
  "name": "{{ display_name }}",
  "version": "{{ version }}",
  "variant": "{{ variant }}",
  "colors": {
    {% for name, c in colors.items() %}
    "{{ name }}": {
      "hex": "{{ c.hex }}",
      "oklch": { "l": {{ "%.3f"|format(c.oklch.l) }}, "c": {{ "%.3f"|format(c.oklch.c) }}, "h": {{ "%.0f"|format(c.oklch.h) }} },
      "role": "{{ c.role }}",
      "category": "{{ c.category }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  },
  "syntax": {
    {% for token, c in syntax.items() %}
    "{{ token }}": "{{ c.hex }}"{% if not loop.last %},{% endif %}
    {% endfor %}
  },
  "ui": {
    {% for role, c in ui.items() %}
    "{{ role }}": "{{ c.hex }}"{% if not loop.last %},{% endif %}
    {% endfor %}
  }
}
