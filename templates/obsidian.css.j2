/* {{ display_name }} — Obsidian CSS snippet
 * Generated by kiln-theme v{{ version }}
 *
 * Installation: copy to .obsidian/snippets/kiln-{{ variant }}.css
 * Enable in Settings → Appearance → CSS snippets
 */

{% if variant == 'dark' %}
.theme-dark {
{% else %}
.theme-light {
{% endif %}
  /* Base colors */
  --background-primary: {{ colors.base.hex }};
  --background-primary-alt: {{ colors.mantle.hex }};
  --background-secondary: {{ colors.mantle.hex }};
  --background-secondary-alt: {{ colors.crust.hex }};

  /* Text colors */
  --text-normal: {{ colors.text.hex }};
  --text-muted: {{ colors.subtext1.hex }};
  --text-faint: {{ colors.comment.hex }};

  /* Interactive colors */
  --interactive-normal: {{ colors.surface0.hex }};
  --interactive-hover: {{ colors.surface1.hex }};
  --interactive-accent: {{ colors.peach.hex }};
  --interactive-accent-hover: {{ colors.maroon.hex }};

  /* Borders */
  --background-modifier-border: {{ colors.surface2.hex }};
  --background-modifier-border-hover: {{ colors.overlay0.hex }};
  --background-modifier-border-focus: {{ colors.peach.hex }};

  /* Headings */
  --h1-color: {{ colors.peach.hex }};
  --h2-color: {{ colors.yellow.hex }};
  --h3-color: {{ colors.gold.hex }};
  --h4-color: {{ colors.green.hex }};
  --h5-color: {{ colors.teal.hex }};
  --h6-color: {{ colors.sapphire.hex }};

  /* Links */
  --link-color: {{ colors.sky.hex }};
  --link-color-hover: {{ colors.sapphire.hex }};
  --link-external-color: {{ colors.sky.hex }};

  /* Inline code */
  --code-normal: {{ colors.peach.hex }};
  --code-background: {{ colors.surface0.hex }};

  /* Code blocks */
  --code-block-alt-bg: {{ colors.mantle.hex }};

  /* Tags */
  --tag-color: {{ colors.mauve.hex }};
  --tag-background: {{ colors.surface0.hex }};
  --tag-color-hover: {{ colors.mauve.hex }};
  --tag-background-hover: {{ colors.surface1.hex }};

  /* Lists */
  --list-marker-color: {{ colors.peach.hex }};
  --checkbox-color: {{ colors.peach.hex }};
  --checkbox-color-hover: {{ colors.maroon.hex }};

  /* Bold and italic */
  --bold-color: {{ colors.text.hex }};
  --italic-color: {{ colors.subtext1.hex }};

  /* Highlights */
  --text-highlight-bg: {{ colors.yellow.hex }}33;
  --text-selection: {{ colors.surface1.hex }};

  /* Cursor */
  --cursor: {{ colors.peach.hex }};

  /* Scrollbar */
  --scrollbar-bg: transparent;
  --scrollbar-thumb-bg: {{ colors.surface2.hex }}66;
  --scrollbar-active-thumb-bg: {{ colors.surface2.hex }}aa;

  /* Graph */
  --graph-line: {{ colors.surface2.hex }};
  --graph-node: {{ colors.peach.hex }};
  --graph-node-focused: {{ colors.sapphire.hex }};

  /* Status bar */
  --status-bar-background: {{ colors.crust.hex }};
  --status-bar-text-color: {{ colors.subtext1.hex }};

  /* Nav */
  --nav-item-color: {{ colors.subtext1.hex }};
  --nav-item-color-hover: {{ colors.text.hex }};
  --nav-item-color-active: {{ colors.peach.hex }};
  --nav-item-background-hover: {{ colors.surface0.hex }};
  --nav-item-background-active: {{ colors.surface1.hex }};

  /* Tab bar */
  --tab-background-active: {{ colors.base.hex }};
  --tab-text-color-focused: {{ colors.peach.hex }};
  --tab-text-color-focused-active: {{ colors.peach.hex }};
  --tab-text-color: {{ colors.comment.hex }};
  --tab-text-color-focused-active-current: {{ colors.peach.hex }};
  --tab-outline-color: transparent;
  --tab-stacked-header-bg: {{ colors.mantle.hex }};
  --tab-container-background: {{ colors.mantle.hex }};
  --tab-divider-color: {{ colors.surface2.hex }};

  /* Ribbon (left sidebar icons) */
  --ribbon-background: {{ colors.crust.hex }};
  --ribbon-background-collapsed: {{ colors.crust.hex }};

  /* Titlebar */
  --titlebar-background: {{ colors.crust.hex }};
  --titlebar-background-focused: {{ colors.crust.hex }};
  --titlebar-text-color: {{ colors.subtext1.hex }};
  --titlebar-text-color-focused: {{ colors.text.hex }};

  /* Workspace area */
  --workspace-background-translucent: {{ colors.crust.hex }};

  /* Sidebar tabs */
  --tab-outline-width: 0px;
}

/* Direct element overrides for areas CSS variables don't reach */
{% if variant == 'dark' %}
.theme-dark .titlebar,
.theme-dark .mod-top .workspace-tab-header-container {
  background-color: {{ colors.mantle.hex }} !important;
}

.theme-dark .workspace-tab-header {
  background-color: {{ colors.mantle.hex }} !important;
}

.theme-dark .workspace-tab-header.is-active {
  background-color: {{ colors.base.hex }} !important;
}

.theme-dark .workspace-tab-header-inner-title {
  color: {{ colors.comment.hex }};
}

.theme-dark .workspace-tab-header.is-active .workspace-tab-header-inner-title {
  color: {{ colors.peach.hex }};
}
{% else %}
.theme-light .titlebar,
.theme-light .mod-top .workspace-tab-header-container {
  background-color: {{ colors.mantle.hex }} !important;
}

.theme-light .workspace-tab-header {
  background-color: {{ colors.mantle.hex }} !important;
}

.theme-light .workspace-tab-header.is-active {
  background-color: {{ colors.base.hex }} !important;
}

.theme-light .workspace-tab-header-inner-title {
  color: {{ colors.comment.hex }};
}

.theme-light .workspace-tab-header.is-active .workspace-tab-header-inner-title {
  color: {{ colors.peach.hex }};
}
{% endif %}

