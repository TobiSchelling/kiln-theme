  --tab-divider-color: {{ dark.surface2.hex }};
  --tab-outline-color: transparent;
  --tab-outline-width: 0px;
  --tab-text-color: {{ dark.comment.hex }};
  --tab-text-color-active: {{ dark.subtext1.hex }};
  --tab-text-color-focused: {{ dark.subtext1.hex }};
  --tab-text-color-focused-active: {{ dark.peach.hex }};
