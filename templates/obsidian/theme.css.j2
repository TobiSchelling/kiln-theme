  --callout-warning: {{ dark.yellow.hex }};
  --callout-fail: {{ dark.red.hex }};
  --callout-error: {{ dark.red.hex }};
  --callout-bug: {{ dark.red.hex }};
  --callout-example: {{ dark.mauve.hex }};
