  --text-on-accent: {{ dark.crust.hex }};
  --text-error: {{ dark.red.hex }};
  --text-success: {{ dark.green.hex }};
  --text-selection: {{ dark.surface1.hex }};
  --text-highlight-bg: {{ dark.yellow.hex }}33;
  --text-highlight-bg-active: {{ dark.yellow.hex }}55;
  --text-accent: {{ dark.peach.hex }};
