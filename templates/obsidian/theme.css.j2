  --background-primary-alt: {{ dark.mantle.hex }};
  --background-secondary: {{ dark.mantle.hex }};
  --background-secondary-alt: {{ dark.crust.hex }};

  --text-normal: {{ dark.text.hex }};
  --text-muted: {{ dark.subtext1.hex }};
