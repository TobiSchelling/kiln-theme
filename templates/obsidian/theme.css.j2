/* Kiln — Obsidian Theme
 * A warm clarity color theme.
 * Generated by kiln-theme v{{ version }}
 *
 * Both dark and light variants included.
 * Obsidian switches between them via Settings → Appearance → Base color scheme.
 */

/* ═══════════════════════════════════════════════════
   DARK VARIANT
   ═══════════════════════════════════════════════════ */

.theme-dark {
  /* ── Core colors ── */
