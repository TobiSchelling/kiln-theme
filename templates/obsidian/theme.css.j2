  /* ── Kiln palette reference (for custom CSS) ── */
  --kiln-red: {{ dark.red.hex }};
  --kiln-maroon: {{ dark.maroon.hex }};
  --kiln-peach: {{ dark.peach.hex }};
  --kiln-yellow: {{ dark.yellow.hex }};
  --kiln-gold: {{ dark.gold.hex }};
  --kiln-green: {{ dark.green.hex }};
  --kiln-teal: {{ dark.teal.hex }};
  --kiln-sky: {{ dark.sky.hex }};
  --kiln-sapphire: {{ dark.sapphire.hex }};
  --kiln-blue: {{ dark.blue.hex }};
  --kiln-lavender: {{ dark.lavender.hex }};
  --kiln-mauve: {{ dark.mauve.hex }};
  --kiln-pink: {{ dark.pink.hex }};
  --kiln-rose: {{ dark.rose.hex }};
