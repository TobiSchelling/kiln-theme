-- {{ display_name }} — Neovim color scheme
-- Generated by kiln-theme v{{ version }}
--
-- Installation: copy the nvim/ directory to ~/.config/nvim/colors/kiln-{{ variant }}/
-- Usage: vim.cmd("colorscheme kiln-{{ variant }}")

local p = require("kiln-{{ variant }}.palette").colors
local highlights = require("kiln-{{ variant }}.highlights").get(p)

vim.cmd("hi clear")
if vim.fn.exists("syntax_on") then
  vim.cmd("syntax reset")
end

vim.o.termguicolors = true
vim.g.colors_name = "kiln-{{ variant }}"

for group, opts in pairs(highlights) do
  vim.api.nvim_set_hl(0, group, opts)
end
