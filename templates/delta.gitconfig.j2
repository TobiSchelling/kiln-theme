# {{ display_name }} — delta (git diff pager) theme
# Generated by kiln-theme v{{ version }}
#
# Add to your ~/.gitconfig:
#   [include]
#     path = ~/.config/delta/kiln-{{ variant }}.gitconfig

[delta "kiln-{{ variant }}"]
    syntax-theme = none
    minus-style = "{{ colors.text.hex }} {{ colors.red.hex }}"
    minus-emph-style = "{{ colors.crust.hex }} {{ colors.red.hex }} bold"
    plus-style = "{{ colors.text.hex }} {{ colors.green.hex }}"
    plus-emph-style = "{{ colors.crust.hex }} {{ colors.green.hex }} bold"
    hunk-header-style = "{{ colors.peach.hex }}"
    hunk-header-decoration-style = "{{ colors.surface2.hex }} ul"
    file-style = "{{ colors.sapphire.hex }} bold"
    file-decoration-style = "{{ colors.surface2.hex }} ul"
    line-numbers-minus-style = "{{ colors.red.hex }}"
    line-numbers-plus-style = "{{ colors.green.hex }}"
    line-numbers-zero-style = "{{ colors.comment.hex }}"
    line-numbers-left-format = "{nm:>3} │"
    line-numbers-right-format = "{np:>3} │"
    line-numbers-left-style = "{{ colors.surface2.hex }}"
    line-numbers-right-style = "{{ colors.surface2.hex }}"
    blame-palette = "{{ colors.base.hex }} {{ colors.mantle.hex }} {{ colors.crust.hex }} {{ colors.surface0.hex }}"
