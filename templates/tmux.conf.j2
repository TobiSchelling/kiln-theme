# {{ display_name }} — tmux theme
# Generated by kiln-theme v{{ version }}
#
# Source this file in your tmux.conf:
#   source-file ~/.config/tmux/kiln-{{ variant }}.conf

# Terminal overrides
set -g default-terminal "tmux-256color"

# Status bar
set -g status-style "bg={{ colors.mantle.hex }},fg={{ colors.subtext1.hex }}"
set -g status-left "#[bg={{ colors.peach.hex }},fg={{ colors.crust.hex }},bold] #S #[default] "
set -g status-right "#[fg={{ colors.comment.hex }}]%Y-%m-%d #[fg={{ colors.subtext1.hex }}]%H:%M "
set -g status-left-length 30
set -g status-right-length 30

# Window status
set -g window-status-format "#[fg={{ colors.comment.hex }}] #I:#W "
set -g window-status-current-format "#[bg={{ colors.surface0.hex }},fg={{ colors.peach.hex }},bold] #I:#W "
set -g window-status-separator ""

# Pane borders
set -g pane-border-style "fg={{ colors.surface2.hex }}"
set -g pane-active-border-style "fg={{ colors.peach.hex }}"

# Message / command mode
set -g message-style "bg={{ colors.surface0.hex }},fg={{ colors.text.hex }}"
set -g message-command-style "bg={{ colors.surface0.hex }},fg={{ colors.text.hex }}"

# Copy mode
set -g mode-style "bg={{ colors.surface1.hex }},fg={{ colors.text.hex }}"

# Clock
set -g clock-mode-colour "{{ colors.sapphire.hex }}"
